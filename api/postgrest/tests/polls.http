### Test with Auth
POST http://localhost:3001/poll
Authorization: Bearer {{token}}
Accept: application/json
Content-Type: application/json

{
  "title": "Test Poll",
  "description": "ASDdsdasdsad <script>alert('XSS')</script>",
  "category_name": "PvP"
}

> {%
    client.test("Test authorized poll creation is successful", function () {
        client.assert(response.status === 201, "Expected status 201 Created, but got " + response.status)
    })
%}